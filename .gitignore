# SFX sintetizados deterministicamente (canhao/clique/tap)
data/sfx/*.wav

# Preferencias locais do jogador (calibracao de latencia por maquina)
data/config/user_settings.json

# Musicas do jogador e beatmaps derivados delas (locais por maquina)
musicas/*
!musicas/LEIA-ME.txt
data/beatmaps/user/

